@startuml Use_Case_Diagram
title Use Case Diagram - Omni Monitor

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEF6D8
  BorderColor #555555
}
skinparam actor {
  BackgroundColor #EAF2FB
  BorderColor #333333
}

actor "Disaster Analyst"      as DA
actor "Environmental Analyst" as EA
actor "Financial Analyst"     as FA

rectangle "Omni Monitor" {
  usecase "View Turkey Map"               as UC1
  usecase "Monitor Earthquakes"           as UC2
  usecase "Detect Wildfires"              as UC3
  usecase "Assess Infrastructure Risk"    as UC4
  usecase "View Climate Alerts"           as UC5
  usecase "Monitor Financial Indicators"  as UC6
  usecase "Read News Feeds"               as UC7
  usecase "Track Custom Keywords"         as UC8
}

DA --> UC1
DA --> UC2
DA --> UC3
DA --> UC8

EA --> UC1
EA --> UC3
EA --> UC4
EA --> UC5

FA --> UC1
FA --> UC6
FA --> UC7

UC3 .> UC4 : <<extend>>
UC8 .> UC7 : <<include>>
UC2 .> UC8 : <<extend>>

@enduml
