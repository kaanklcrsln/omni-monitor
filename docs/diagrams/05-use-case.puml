@startuml Use_Case_Diagram
title Use Case Diagram - Omni Monitor

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEF6D8
  BorderColor #555555
}
skinparam actor {
  BackgroundColor #EAF2FB
  BorderColor #333333
}

actor "Disaster Analyst"      as DA
actor "Environmental Analyst" as EA
actor "Financial Analyst"     as FA

rectangle "Omni Monitor" {
  usecase UC1 as "View Turkey Map"
  usecase UC2 as "Monitor Earthquakes"
  usecase UC3 as "Detect Wildfires"
  usecase UC4 as "Assess Infrastructure Risk"
  usecase UC5 as "View Climate Alerts"
  usecase UC6 as "Monitor Financial Indicators"
  usecase UC7 as "Read News Feeds"
  usecase UC8 as "Track Custom Keywords"
}

DA --> UC1
DA --> UC2
DA --> UC3
DA --> UC8

EA --> UC1
EA --> UC3
EA --> UC4
EA --> UC5

FA --> UC1
FA --> UC6
FA --> UC7

UC3 .> UC4 : <<extend>>
UC8 .> UC7 : <<include>>
UC2 .> UC8 : <<extend>>

@enduml
